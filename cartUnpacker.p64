--[[pod_format="raw",created="2025-01-17 10:35:48",modified="2025-04-18 23:30:11",revision=995]]
-- CartUnpacker.p64

-- ver de crear parte visual tipo window de picotron, y que puedas elegir cart, y path

function _init()
	local cart_path = "/git/cartUnpcaker/typer.p64/" -- o donde este el cart
	local output_folder = "/git/cartUnpcaker/test/"
	local build_folder = "/git/cartUnpcaker/typer.p64/" -- cambiar el final por el nombre del cart
	
--	unpack_cart(cart_path, output_folder)
--	pack_cart(output_folder, build_folder)
end

function pack_cart(folder_path, output_folder)
	local files = ls(folder_path)
	if not files then
	   print("No se pudo leer el folder.")
		return
	end
	
	mkdir(output_folder)
	
	store_files(folder_path, output_folder, files)
	
	print("Cart updated: "..output_folder)
end

function unpack_cart(cart_path, output_folder)
   -- listar archivos dentro del cart
	local files = ls(cart_path)
	if not files then
	    print("No se pudo leer el cart.")
	    return
	end
	
	mkdir(output_folder)

	store_files(cart_path, output_folder, files)
	
	print("Cartucho desempaquetado en: "..output_folder)
end

function store_files(cart_path, output_folder, files)
	for file in all(files) do
		local input_path = cart_path..file
		local output_path = output_folder..file
		local data = fetch(input_path)		
		
		if data then
			store(output_path, data)
			print(file.." exportado.")
		else
			mkdir(output_path)
			print(output_path.." was created")
			store_files(cart_path..file.."/", output_path.."/", ls(cart_path.."/"..file))
		end
	end
end
